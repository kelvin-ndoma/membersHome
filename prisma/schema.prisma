enum LiveStreamStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveStreamViewer {
  id       String     @id @default(auto()) @map("_id") @db.ObjectId
  streamId String     @db.ObjectId
  stream   LiveStream @relation(fields: [streamId], references: [id])

  viewerId String @db.ObjectId
  viewer   User   @relation("UserStreamViewer", fields: [viewerId], references: [id])

  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  duration Int?

  @@unique([streamId, viewerId])
  @@index([streamId])
  @@index([viewerId])
}

model CommunityEvent {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  communityId String    @db.ObjectId
  community   Community @relation(fields: [communityId], references: [id])

  organizerId String @db.ObjectId
  organizer   User   @relation("EventOrganizer", fields: [organizerId], references: [id])

  title       String
  description String?
  location    String?
  onlineUrl   String?

  startAt DateTime
  endAt   DateTime

  isVirtual    Boolean @default(false)
  requiresRSVP Boolean @default(true)
  maxAttendees Int?

  attendeeCount Int @default(0)

  status CommunityEventStatus @default(SCHEDULED)

  rsvps CommunityEventRSVP[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([communityId, startAt])
  @@index([organizerId])
  @@index([status])
}

enum CommunityEventStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

model CommunityEventRSVP {
  id      String         @id @default(auto()) @map("_id") @db.ObjectId
  eventId String         @db.ObjectId
  event   CommunityEvent @relation(fields: [eventId], references: [id])

  memberId String          @db.ObjectId
  member   CommunityMember @relation("MemberRSVPs", fields: [memberId], references: [id])

  userId String @db.ObjectId
  user   User   @relation("UserRSVPs", fields: [userId], references: [id])

  status     CommunityRSVPStatus @default(CONFIRMED)
  attendedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
}

enum CommunityRSVPStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

model CommunityCategory {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  communityId String    @db.ObjectId
  community   Community @relation(fields: [communityId], references: [id])

  name        String
  slug        String
  description String?
  icon        String?

  postCount Int @default(0)

  createdAt DateTime @default(now())

  @@unique([communityId, slug])
}

model CommunityModerator {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  communityId String    @db.ObjectId
  community   Community @relation(fields: [communityId], references: [id])

  moderatorId String          @db.ObjectId
  moderator   CommunityMember @relation("MemberModerator", fields: [moderatorId], references: [id])

  userId String @db.ObjectId
  user   User   @relation("UserModerator", fields: [userId], references: [id])

  permissions Json @default("[]")

  assignedBy String   @db.ObjectId
  assignedAt DateTime @default(now())

  @@unique([communityId, moderatorId])
}
