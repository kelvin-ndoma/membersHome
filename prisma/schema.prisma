  @@index([communityId, role])
  @@index([userId])
  @@index([status])
  @@index([houseMembershipId])
}

enum CommunityRole {
  MEMBER
  MODERATOR
  ADMIN
  OWNER
}

enum CommunityMemberStatus {
  ACTIVE
  PENDING
  BANNED
  LEFT
}

model CommunityPost {
