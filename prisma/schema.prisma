model CommunityPostShare {
  id       String        @id @default(auto()) @map("_id") @db.ObjectId
  postId   String        @db.ObjectId
  post     CommunityPost @relation(fields: [postId], references: [id])
  userId   String        @db.ObjectId
  user     User          @relation("UserPostShares", fields: [userId], references: [id])
  sharedAt DateTime      @default(now())

  @@unique([postId, userId])
}

model CommunityProduct {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  communityId String    @db.ObjectId
  community   Community @relation(fields: [communityId], references: [id])

  sellerId String @db.ObjectId
  seller   User   @relation("ProductSeller", fields: [sellerId], references: [id])

  name           String
  description    String?
  price          Float
  compareAtPrice Float?
  currency       String  @default("USD")

  type      ProductType @default(PHYSICAL)
  category  String?
  images    String[]    @default([])
  inventory Int?

  fileUrl       String?
  downloadLimit Int?    @default(0)

  isPublished      Boolean @default(false)
  requiresShipping Boolean @default(false)
  isDigital        Boolean @default(false)

  salesCount Int   @default(0)
  revenue    Float @default(0)

  status ProductStatus @default(ACTIVE)

  purchases CommunityPurchase[]

    // Fee configuration for this product
  houseFeePercent   Float?  @default(0)  // What % the house takes from this sale
  platformFeePercent Float? @default(0)  // What % the platform takes
  sellerPayoutAmount Float?              // Calculated amount seller receives after fees
  houseEarnings      Float?              // Calculated amount house earns
  platformEarnings   Float?              // Calculated amount platform earns

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([communityId, status])
  @@index([sellerId])
  @@index([type])
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
  DONATION
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
  DRAFT
}

model CommunityPurchase {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  productId String           @db.ObjectId
  product   CommunityProduct @relation(fields: [productId], references: [id])

  buyerId String @db.ObjectId
  buyer   User   @relation("PurchaseBuyer", fields: [buyerId], references: [id])

  quantity    Int    @default(1)
  unitPrice   Float
  totalAmount Float
  currency    String @default("USD")

  shippingAddress Json?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  downloadToken   String?
  downloadExpires DateTime?
  downloadCount   Int       @default(0)

  paymentId String?  @db.ObjectId
  payment   Payment? @relation(fields: [paymentId], references: [id])

  status PurchaseStatus @default(PENDING)

  // Fee tracking
  houseFeeAmount    Float?  // Amount taken by house
  platformFeeAmount Float?  // Amount taken by platform
  sellerPayoutAmount Float? // Amount seller receives
  houseFeePercent   Float?  // Percentage applied
  platformFeePercent Float? // Percentage applied
  
  // Payout tracking
  sellerPaidAt      DateTime?
  housePaidAt       DateTime?
  platformPaidAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([buyerId])
  @@index([status])
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model LiveStream {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  communityId String    @db.ObjectId
  community   Community @relation(fields: [communityId], references: [id])

  hostId String @db.ObjectId
  host   User   @relation("StreamHost", fields: [hostId], references: [id])

