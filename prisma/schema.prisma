  name        String
  slug        String
  description String?
  coverImage  String?
  logoUrl     String?

  houseId String @db.ObjectId
  house   House  @relation(fields: [houseId], references: [id])

  createdBy String @db.ObjectId
  creator   User   @relation("CommunityCreator", fields: [createdBy], references: [id])

  // Settings
  isPrivate        Boolean @default(false)
  requiresApproval Boolean @default(false)
  maxMembers       Int?

  // Community branding (overrides house)
  useCustomBranding Boolean @default(false)
  primaryColor      String?
  secondaryColor    String?
  accentColor       String?

  // Live streaming
  liveEnabled      Boolean   @default(true)
  currentLiveUrl   String?
  currentLiveTitle String?
  liveStartedAt    DateTime?
  liveViewers      Int       @default(0)

  // Stats
  memberCount  Int @default(0)
  postCount    Int @default(0)
  productCount Int @default(0)
  liveCount    Int @default(0)

  status CommunityStatus @default(ACTIVE)

  // Relations
  members     CommunityMember[]
  posts       CommunityPost[]
  products    CommunityProduct[]
  liveStreams LiveStream[]
  events      CommunityEvent[]
  categories  CommunityCategory[]
  moderators  CommunityModerator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseId, slug])
  @@index([houseId, status])
  @@index([createdBy])
}

enum CommunityStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

model CommunityMember {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
