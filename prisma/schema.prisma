generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  phone         String?

  mfaSecret   String?
  mfaEnabled  Boolean   @default(false)
  lastLoginAt DateTime?
  lastLoginIp String?

  platformRole PlatformRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions              Session[]
  memberships           Membership[]
  createdEvents         Event[]          @relation("EventCreator")
  ticketPurchases       TicketPurchase[]
  payments              Payment[]
  auditLogs             AuditLog[]
  createdReports        Report[]         @relation("ReportGenerator")
  createdCommunications Communication[]  @relation("CommunicationCreator")
  createdInvoices       Invoice[]        @relation("InvoiceCreator")
  paidInvoices          Invoice[]        @relation("InvoicePayer")
}

enum PlatformRole {
  USER
  PLATFORM_ADMIN
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id])

  @@index([expires])
  @@index([userId])
}

model Organization {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String  @unique
  description String?
  logoUrl     String?
  website     String?

  plan         PlanType           @default(FREE)
  billingEmail String?
  status       OrganizationStatus @default(ACTIVE)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  primaryColor   String? @default("#3B82F6")
  secondaryColor String? @default("#1E40AF")
  customDomain   String?

  settings Json @default("{}")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  suspendedAt DateTime?

  memberships     Membership[]
  houses          House[]
  events          Event[]
  tickets         Ticket[]
  invoices        Invoice[]
  payments        Payment[]
  reports         Report[]
  communications  Communication[]
  auditLogs       AuditLog[]
  rsvps           RSVP[]
  ticketPurchases TicketPurchase[]

  @@index([status])
  @@index([customDomain])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

enum PlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

model Membership {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId         String @db.ObjectId
  organizationId String @db.ObjectId

  organizationRole OrganizationRole @default(MEMBER)
  status           MembershipStatus @default(ACTIVE)

  title        String?
  bio          String?
  phone        String?
  joinedAt     DateTime  @default(now())
  invitedBy    String?   @db.ObjectId
  invitedAt    DateTime?
  acceptedAt   DateTime?
  lastActiveAt DateTime?

  // Remove @unique from invitationToken
  invitationToken String?  // No @unique

  permissions Json? @default("[]")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  houseMemberships  HouseMembership[]
  invoices          Invoice[]
  ticketPurchases   TicketPurchase[]
  ticketValidations TicketValidation[] @relation("ValidatorMembership")
  rsvps             RSVP[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, status])
  @@index([userId, status])
  @@index([organizationId, organizationRole])
}

enum OrganizationRole {
  MEMBER
  ORG_ADMIN
  ORG_OWNER
}

enum MembershipStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  BANNED
}

model House {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  name           String
  slug           String
  description    String?
  logoUrl        String?

  isPrivate Boolean @default(false)
  settings  Json    @default("{}")

  organization   Organization      @relation(fields: [organizationId], references: [id])
  members        HouseMembership[]
  events         Event[]
  tickets        Ticket[]
  communications Communication[]
  reports        Report[]
  payments       Payment[]
  auditLogs      AuditLog[]
  rsvps          RSVP[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  ticketPurchases TicketPurchase[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model HouseMembership {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  houseId      String @db.ObjectId
  membershipId String @db.ObjectId

  role   HouseRole        @default(HOUSE_MEMBER)
  status MembershipStatus @default(ACTIVE)

  staffPosition String?
  managerLevel  Int?    @default(1)

  joinedAt DateTime @default(now())

  house      House      @relation(fields: [houseId], references: [id])
  membership Membership @relation(fields: [membershipId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseId, membershipId])
  @@index([houseId, role, status])
  @@index([membershipId])
}

enum HouseRole {
  HOUSE_MEMBER
  HOUSE_STAFF
  HOUSE_MANAGER
  HOUSE_ADMIN
}

model Event {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId
  createdBy      String  @db.ObjectId

  title       String
  slug        String
  description String?

  startDate DateTime
  endDate   DateTime
  timezone  String    @default("UTC")
  location  String?
  address   Json?
  onlineUrl String?
  type      EventType @default(IN_PERSON)

  isFree   Boolean @default(true)
  capacity Int?
  price    Float?  @default(0)
  currency String  @default("USD")

  status      EventStatus @default(DRAFT)
  publishedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])
  creator      User         @relation("EventCreator", fields: [createdBy], references: [id])

  rsvps   RSVP[]
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, houseId])
  @@index([startDate, status])
}

enum EventType {
  IN_PERSON
  ONLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

model RSVP {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  eventId        String  @db.ObjectId
  membershipId   String  @db.ObjectId
  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId

  status      RSVPStatus @default(PENDING)
  guestsCount Int        @default(0)
  notes       String?

  checkedInAt DateTime?
  checkedInBy String?   @db.ObjectId

  amountPaid Float?  @default(0)
  currency   String? @default("USD")

  event        Event        @relation(fields: [eventId], references: [id])
  membership   Membership   @relation(fields: [membershipId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, membershipId])
  @@index([organizationId])
  @@index([houseId])
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  ATTENDED
}

model Ticket {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId
  eventId        String? @db.ObjectId

  name        String
  description String?
  slug        String?
  type        TicketType @default(GENERAL_ADMISSION)

  price          Float
  currency       String @default("USD")
  earlyBirdPrice Float?
  memberPrice    Float?
  publicPrice    Float?

  totalQuantity    Int
  soldQuantity     Int @default(0)
  reservedQuantity Int @default(0)
  maxPerPurchase   Int @default(10)

  memberOnly       Boolean @default(false)
  requiresApproval Boolean @default(false)

  salesStartAt DateTime
  salesEndAt   DateTime
  validFrom    DateTime
  validUntil   DateTime

  isPublic       Boolean      @default(true)
  isRefundable   Boolean      @default(true)
  refundDeadline DateTime?
  metadata       Json         @default("{}")
  status         TicketStatus @default(DRAFT)

  createdBy String @db.ObjectId

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])

  purchases   TicketPurchase[]
  validations TicketValidation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, houseId, status])
  @@index([eventId])
  @@index([slug])
}

enum TicketType {
  GENERAL_ADMISSION
  VIP
  EARLY_BIRD
  GROUP
  SEASON_PASS
  WORKSHOP
  COURSE
  DONATION
  CUSTOM
}

enum TicketStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  CANCELLED
  EXPIRED
}

model TicketPurchase {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  ticketId       String  @db.ObjectId
  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId
  membershipId   String? @db.ObjectId
  userId         String? @db.ObjectId

  quantity    Int
  unitPrice   Float
  totalAmount Float
  currency    String @default("USD")

  customerName  String?
  customerEmail String?
  customerPhone String?

  paymentStatus PaymentStatus @default(PENDING)
  paidAt        DateTime?
  paymentMethod String?

  ticketCodes Json    @default("[]")
  usedCount   Int     @default(0)
  fullyUsed   Boolean @default(false)

  metadata Json    @default("{}")
  notes    String?

  ticket       Ticket             @relation(fields: [ticketId], references: [id])
  organization Organization       @relation(fields: [organizationId], references: [id])
  house        House?             @relation(fields: [houseId], references: [id])
  membership   Membership?        @relation(fields: [membershipId], references: [id])
  user         User?              @relation(fields: [userId], references: [id])
  validations  TicketValidation[]
  payments     Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@index([organizationId, paymentStatus])
  @@index([membershipId])
  @@index([userId])
}

model TicketValidation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  ticketId              String  @db.ObjectId
  purchaseId            String  @db.ObjectId
  validatorMembershipId String? @db.ObjectId

  ticketCode    String
  attendeeName  String?
  attendeeEmail String?

  validatedAt   DateTime @default(now())
  entryPoint    String?
  gateNumber    String?
  isValid       Boolean  @default(true)
  invalidReason String?
  isReentry     Boolean  @default(false)

  ticket    Ticket         @relation(fields: [ticketId], references: [id])
  purchase  TicketPurchase @relation(fields: [purchaseId], references: [id])
  validator Membership?    @relation("ValidatorMembership", fields: [validatorMembershipId], references: [id])

  @@index([ticketId])
  @@index([purchaseId])
  @@index([validatorMembershipId])
  @@index([ticketCode])
}

model Invoice {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  invoiceNumber  String @unique
  organizationId String @db.ObjectId
  membershipId   String @db.ObjectId

  amount      Float
  currency    String    @default("USD")
  description String?
  dueDate     DateTime?
  items       Json      @default("[]")

  status      InvoiceStatus @default(DRAFT)
  paidAt      DateTime?
  paidBy      String?       @db.ObjectId
  cancelledAt DateTime?

  createdBy String @db.ObjectId

  organization Organization @relation(fields: [organizationId], references: [id])
  membership   Membership   @relation(fields: [membershipId], references: [id])
  creator      User         @relation("InvoiceCreator", fields: [createdBy], references: [id])
  payer        User?        @relation("InvoicePayer", fields: [paidBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([membershipId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model Payment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId   String  @db.ObjectId
  houseId          String? @db.ObjectId
  userId           String  @db.ObjectId
  ticketPurchaseId String? @db.ObjectId

  stripePaymentId  String
  stripeCustomerId String?
  amount           Float
  currency         String  @default("USD")
  description      String?
  metadata         Json    @default("{}")

  status     PaymentStatus @default(PENDING)
  paidAt     DateTime?
  refundedAt DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id])
  house          House?          @relation(fields: [houseId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  ticketPurchase TicketPurchase? @relation(fields: [ticketPurchaseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([userId])
  @@index([ticketPurchaseId])
  @@index([stripePaymentId])
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
}

model Communication {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId
  createdBy      String  @db.ObjectId

  subject String
  body    String
  type    CommunicationType @default(EMAIL)

  recipientType  RecipientType @default(ALL_MEMBERS)
  segmentFilters Json?

  status       CommunicationStatus @default(DRAFT)
  scheduledFor DateTime?
  sentAt       DateTime?

  sentCount    Int @default(0)
  openedCount  Int @default(0)
  clickedCount Int @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])
  creator      User         @relation("CommunicationCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([houseId, status])
}

enum CommunicationType {
  EMAIL
  ANNOUNCEMENT
  PUSH_NOTIFICATION
}

enum RecipientType {
  ALL_MEMBERS
  HOUSE_MEMBERS
  EVENT_ATTENDEES
  TICKET_BUYERS
  CUSTOM_SEGMENT
}

enum CommunicationStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Report {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId

  type        ReportType
  title       String
  description String?

  parameters Json
  data       Json

  generatedBy String            @db.ObjectId
  generatedAt DateTime          @default(now())
  accessLevel ReportAccessLevel @default(ORGANIZATION)

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])
  generator    User         @relation("ReportGenerator", fields: [generatedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, type])
  @@index([houseId, type])
}

enum ReportType {
  MEMBERSHIP_GROWTH
  EVENT_ATTENDANCE
  REVENUE_ANALYSIS
  ENGAGEMENT_METRICS
  EMAIL_PERFORMANCE
  TICKET_SALES
  PLATFORM_OVERVIEW
}

enum ReportAccessLevel {
  HOUSE_ONLY
  ORGANIZATION
  PLATFORM
}

model AuditLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId    String? @db.ObjectId
  userEmail String?
  userIp    String?
  userAgent String?

  action     String
  entityType String
  entityId   String?

  organizationId String? @db.ObjectId
  houseId        String? @db.ObjectId

  oldValues Json?
  newValues Json?
  metadata  Json?

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  house        House?        @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([organizationId, action])
  @@index([houseId, action])
  @@index([entityType, entityId])
}