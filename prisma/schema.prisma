generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ========================
// PLATFORM LEVEL
// ========================
model Platform {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @default("membersHome")
  description String?
  settings    Json     @default("{}")
  
  allowCustomDomains   Boolean   @default(true)
  maxOrganizations     Int?
  defaultPlanForNewOrgs PlanType @default(FREE)
  
  logoUrl     String?
  faviconUrl  String?
  primaryColor String?  @default("#3B82F6")
  secondaryColor String? @default("#1E40AF")
  
  stripePlatformAccountId String? @unique
  platformFeePercent      Float?  @default(0)
  
  enableMultiTenancy    Boolean @default(true)
  enableMemberMessaging Boolean @default(true)
  enableMemberDirectory Boolean @default(true)
  
  organizations Organization[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================
// USER & AUTHENTICATION
// ========================
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  phone         String?

  mfaSecret   String?
  mfaEnabled  Boolean   @default(false)
  lastLoginAt DateTime?
  lastLoginIp String?

  platformRole PlatformRole @default(USER)

  invitationToken      String?
  invitationSentAt     DateTime?
  invitationAcceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions              Session[]
  memberships           Membership[]
  createdEvents         Event[]          @relation("EventCreator")
  ticketPurchases       TicketPurchase[]
  payments              Payment[]
  auditLogs             AuditLog[]
  createdReports        Report[]         @relation("ReportGenerator")
  createdCommunications Communication[]  @relation("CommunicationCreator")
  createdInvoices       Invoice[]        @relation("InvoiceCreator")
  paidInvoices          Invoice[]        @relation("InvoicePayer")

  reviewedApplications    MembershipApplication[] @relation("ApplicationReviewer")
  membershipItems         MembershipItem[]
  cancelledMemberships    MembershipItem[]        @relation("MembershipCanceller")
  reviewedFormSubmissions FormSubmission[]        @relation("FormSubmissionReviewer")
  customer                Customer?
  memberProfile           MemberProfile?
  memberDashboard         MemberDashboard?
  memberActivities        MemberActivity[]
  sentMemberMessages      MemberMessage[]         @relation("SentMemberMessages")
  receivedMemberMessages  MemberMessage[]         @relation("ReceivedMemberMessages")
  cancellationRequests    CancellationRequest[]
  reviewedCancellations   CancellationRequest[]   @relation("CancellationReviewer")
}

enum PlatformRole {
  USER
  PLATFORM_ADMIN
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id])

  @@index([expires])
  @@index([userId])
}

// ========================
// CUSTOMER & PAYMENTS
// ========================
model Customer {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  stripeCustomerId      String   @unique
  userId                String   @unique @db.ObjectId
  defaultPaymentMethodId String?
  
  user         User     @relation(fields: [userId], references: [id])
  membershipItems MembershipItem[]
  payments     Payment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================
// ORGANIZATION & TENANCY
// ========================
model Organization {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String  @unique
  description String?
  logoUrl     String?
  website     String?
  
  platformId  String? @db.ObjectId
  platform    Platform? @relation(fields: [platformId], references: [id])

  plan         PlanType           @default(FREE)
  billingEmail String?
  status       OrganizationStatus @default(ACTIVE)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  primaryColor   String? @default("#3B82F6")
  secondaryColor String? @default("#1E40AF")
  customDomain   String?

  settings Json @default("{}")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  suspendedAt DateTime?

  memberships     Membership[]
  houses          House[]
  events          Event[]
  tickets         Ticket[]
  invoices        Invoice[]
  payments        Payment[]
  reports         Report[]
  communications  Communication[]
  auditLogs       AuditLog[]
  rsvps           RSVP[]
  ticketPurchases TicketPurchase[]

  membershipPlans        MembershipPlan[]
  membershipApplications MembershipApplication[]
  membershipItems        MembershipItem[]
  customForms            CustomForm[]
  memberPortals          MemberPortal[]
  memberMessages         MemberMessage[]

  @@index([status])
  @@index([customDomain])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([platformId])
}

enum PlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

// ========================
// MEMBERSHIP & ROLES
// ========================
model Membership {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId         String @db.ObjectId
  organizationId String @db.ObjectId

  organizationRole OrganizationRole @default(MEMBER)
  status           MembershipStatus @default(ACTIVE)

  title        String?
  bio          String?
  phone        String?
  joinedAt     DateTime  @default(now())
  invitedBy    String?   @db.ObjectId
  invitedAt    DateTime?
  acceptedAt   DateTime?
  lastActiveAt DateTime?

  invitationToken String?

  permissions Json? @default("[]")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  houseMemberships  HouseMembership[]
  invoices          Invoice[]
  ticketPurchases   TicketPurchase[]
  ticketValidations TicketValidation[] @relation("ValidatorMembership")
  rsvps             RSVP[]

  memberProfile   MemberProfile?
  memberDashboard MemberDashboard?
  memberActivities MemberActivity[]
  cancellationRequests CancellationRequest[]
  
  sentMemberMessages   MemberMessage[] @relation("SentMemberMessages")
  receivedMemberMessages MemberMessage[] @relation("ReceivedMemberMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, status])
  @@index([userId, status])
  @@index([organizationId, organizationRole])
}

enum OrganizationRole {
  MEMBER
  ORG_ADMIN
  ORG_OWNER
}

enum MembershipStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  BANNED
}

// ========================
// HOUSE (SUB-UNIT/TEAM)
// ========================
model House {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  name           String
  slug           String
  description    String?
  logoUrl        String?

  isPrivate Boolean @default(false)
  settings  Json    @default("{}")

  organization   Organization      @relation(fields: [organizationId], references: [id])
  members        HouseMembership[]
  events         Event[]
  tickets        Ticket[]
  communications Communication[]
  reports        Report[]
  payments       Payment[]
  auditLogs      AuditLog[]
  rsvps          RSVP[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  ticketPurchases TicketPurchase[]

  membershipPlans MembershipPlan[]
  customForms     CustomForm[]
  memberPortal    MemberPortal?
  memberProfiles  MemberProfile[]
  memberDashboards MemberDashboard[]
  memberMessages  MemberMessage[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model HouseMembership {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  houseId      String @db.ObjectId
  membershipId String @db.ObjectId

  role   HouseRole        @default(HOUSE_MEMBER)
  status MembershipStatus @default(ACTIVE)

  staffPosition String?
  managerLevel  Int?    @default(1)

  joinedAt DateTime @default(now())

  house      House      @relation(fields: [houseId], references: [id])
  membership Membership @relation(fields: [membershipId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseId, membershipId])
  @@index([houseId, role, status])
  @@index([membershipId])
}

enum HouseRole {
  HOUSE_MEMBER
  HOUSE_STAFF
  HOUSE_MANAGER
  HOUSE_ADMIN
}

// ========================
// MEMBER PORTAL
// ========================
model MemberPortal {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  houseId        String   @unique @db.ObjectId
  organizationId String   @db.ObjectId
  
  theme       Json     @default("{}")
  navigation  Json     @default("{}")
  features    Json     @default("{}")
  
  requireMFAForPortal Boolean @default(false)
  sessionTimeout     Int     @default(480)
  allowedDomains     String[] @default([])
  
  welcomeMessage String?
  customCSS      String?
  customJS       String?
  
  metaTitle     String?
  metaDescription String?
  
  house        House        @relation(fields: [houseId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================
// MEMBER PROFILE
// ========================
model MemberProfile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  membershipId String   @unique @db.ObjectId
  userId       String   @unique @db.ObjectId
  houseId      String   @db.ObjectId
  
  avatar       String?
  bio          String?
  phone        String?
  address      Json?
  emergencyContact Json?
  
  notificationPreferences Json @default("{}")
  privacySettings        Json @default("{}")
  language              String @default("en")
  timezone              String @default("UTC")
  
  jobTitle     String?
  company      String?
  industry     String?
  skills       String[] @default([])
  interests    String[] @default([])
  
  socialLinks  Json @default("{}")
  
  membership   Membership @relation(fields: [membershipId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  house        House      @relation(fields: [houseId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================
// MEMBER DASHBOARD
// ========================
model MemberDashboard {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  membershipId String   @unique @db.ObjectId
  userId       String   @unique @db.ObjectId
  houseId      String   @db.ObjectId
  
  widgetLayout Json @default("{}")
  pinnedItems  String[] @default([])
  
  lastPortalLoginAt DateTime?
  lastPortalLoginIp String?
  portalLoginCount  Int @default(0)
  
  savedEvents        String[] @default([])
  savedAnnouncements String[] @default([])
  
  defaultView      String @default("grid")
  emailDigest      Boolean @default(true)
  digestFrequency  String @default("weekly")
  
  membership   Membership @relation(fields: [membershipId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  house        House      @relation(fields: [houseId], references: [id])
  
  activities   MemberActivity[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemberActivity {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  membershipId String   @db.ObjectId
  dashboardId  String   @db.ObjectId
  userId       String   @db.ObjectId
  
  activityType ActivityType
  entityId     String
  entityType   String
  metadata     Json     @default("{}")
  
  performedAt  DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  
  membership   Membership       @relation(fields: [membershipId], references: [id])
  dashboard    MemberDashboard  @relation(fields: [dashboardId], references: [id])
  user         User             @relation(fields: [userId], references: [id])
  
  @@index([membershipId, performedAt])
  @@index([activityType])
  @@index([userId])
}

enum ActivityType {
  PAGE_VIEW
  EVENT_RSVP
  EVENT_CHECKIN
  TICKET_PURCHASE
  TICKET_DOWNLOAD
  ANNOUNCEMENT_VIEW
  PROFILE_UPDATE
  PASSWORD_CHANGE
  BILLING_UPDATE
  SUBSCRIPTION_CHANGE
  CANCELLATION_REQUEST
  MESSAGE_SENT
  MESSAGE_READ
}

// ========================
// MEMBER MESSAGING
// ========================
model MemberMessage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  fromMembershipId String @db.ObjectId
  toMembershipId   String @db.ObjectId
  fromUserId       String @db.ObjectId
  toUserId         String @db.ObjectId
  houseId      String   @db.ObjectId
  organizationId String @db.ObjectId
  
  subject      String
  message      String
  isRead       Boolean  @default(false)
  readAt       DateTime?
  parentMessageId String? @db.ObjectId
  
  status       MessageStatus @default(SENT)
  
  fromMembership Membership @relation("SentMemberMessages", fields: [fromMembershipId], references: [id])
  toMembership   Membership @relation("ReceivedMemberMessages", fields: [toMembershipId], references: [id])
  fromUser       User       @relation("SentMemberMessages", fields: [fromUserId], references: [id])
  toUser         User       @relation("ReceivedMemberMessages", fields: [toUserId], references: [id])
  house          House      @relation(fields: [houseId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  parentMessage  MemberMessage? @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies        MemberMessage[] @relation("MessageThread")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([fromMembershipId, createdAt])
  @@index([toMembershipId, isRead])
  @@index([organizationId])
  @@index([houseId])
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  DELETED
}

// ========================
// CANCELLATION REQUESTS
// ========================
model CancellationRequest {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  membershipId String   @db.ObjectId
  membershipItemId String @db.ObjectId
  userId       String   @db.ObjectId
  
  reason       CancellationReason
  reasonDetail String?
  effectiveDate DateTime
  feedback     String?
  
  status       RequestStatus @default(PENDING)
  reviewedBy   String?       @db.ObjectId
  reviewedAt   DateTime?
  approvedAt   DateTime?
  deniedReason String?
  
  autoProcessAt DateTime?
  processedAt   DateTime?
  
  membership     Membership     @relation(fields: [membershipId], references: [id])
  membershipItem MembershipItem @relation(fields: [membershipItemId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  reviewer       User?          @relation("CancellationReviewer", fields: [reviewedBy], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([membershipId, status])
  @@index([membershipItemId])
}

enum CancellationReason {
  TOO_EXPENSIVE
  NOT_USING
  MOVING
  HEALTH_REASONS
  SERVICE_ISSUES
  OTHER
}

enum RequestStatus {
  PENDING
  APPROVED
  DENIED
  PROCESSED
}

// ========================
// EVENTS & RSVPS (continued)
// ========================
model Event {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId
  createdBy      String  @db.ObjectId

  title       String
  slug        String
  description String?
  imageUrl    String?

  startDate DateTime
  endDate   DateTime
  timezone  String    @default("UTC")
  location  String?
  address   Json?
  onlineUrl String?
  type      EventType @default(IN_PERSON)

  isFree     Boolean @default(true)
  capacity   Int?
  price      Float?  @default(0)
  currency   String  @default("USD")
  memberOnly Boolean @default(false)

  status      EventStatus @default(DRAFT)
  publishedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])
  creator      User         @relation("EventCreator", fields: [createdBy], references: [id])

  rsvps   RSVP[]
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, houseId])
  @@index([startDate, status])
}

enum EventType {
  IN_PERSON
  ONLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

model RSVP {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  eventId        String  @db.ObjectId
  membershipId   String  @db.ObjectId
  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId

  status      RSVPStatus @default(PENDING)
  guestsCount Int        @default(0)
  notes       String?

  checkedInAt DateTime?
  checkedInBy String?   @db.ObjectId

  amountPaid Float?  @default(0)
  currency   String? @default("USD")

  event        Event        @relation(fields: [eventId], references: [id])
  membership   Membership   @relation(fields: [membershipId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, membershipId])
  @@index([organizationId])
  @@index([houseId])
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  ATTENDED
}

// ========================
// TICKETS & PURCHASES
// ========================
model Ticket {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId
  eventId        String? @db.ObjectId

  name        String
  description String?
  slug        String?
  type        TicketType @default(GENERAL_ADMISSION)

  price          Float
  currency       String @default("USD")
  earlyBirdPrice Float?
  memberPrice    Float?
  publicPrice    Float?

  totalQuantity    Int
  soldQuantity     Int @default(0)
  reservedQuantity Int @default(0)
  maxPerPurchase   Int @default(10)

  memberOnly       Boolean @default(false)
  requiresApproval Boolean @default(false)

  salesStartAt DateTime
  salesEndAt   DateTime
  validFrom    DateTime
  validUntil   DateTime

  isPublic       Boolean      @default(true)
  isRefundable   Boolean      @default(true)
  refundDeadline DateTime?
  metadata       Json         @default("{}")
  status         TicketStatus @default(DRAFT)

  createdBy String @db.ObjectId

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])

  purchases   TicketPurchase[]
  validations TicketValidation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, houseId, status])
  @@index([eventId])
  @@index([slug])
}

enum TicketType {
  GENERAL_ADMISSION
  VIP
  EARLY_BIRD
  GROUP
  SEASON_PASS
  WORKSHOP
  COURSE
  DONATION
  CUSTOM
}

enum TicketStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  CANCELLED
  EXPIRED
}

model TicketPurchase {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  ticketId       String  @db.ObjectId
  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId
  membershipId   String? @db.ObjectId
  userId         String? @db.ObjectId

  quantity    Int
  unitPrice   Float
  totalAmount Float
  currency    String @default("USD")

  customerName  String?
  customerEmail String?
  customerPhone String?

  paymentStatus PaymentStatus @default(PENDING)
  paidAt        DateTime?
  paymentMethod String?

  ticketCodes Json    @default("[]")
  usedCount   Int     @default(0)
  fullyUsed   Boolean @default(false)

  metadata Json    @default("{}")
  notes    String?

  ticket       Ticket             @relation(fields: [ticketId], references: [id])
  organization Organization       @relation(fields: [organizationId], references: [id])
  house        House?             @relation(fields: [houseId], references: [id])
  membership   Membership?        @relation(fields: [membershipId], references: [id])
  user         User?              @relation(fields: [userId], references: [id])
  validations  TicketValidation[]
  payments     Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@index([organizationId, paymentStatus])
  @@index([membershipId])
  @@index([userId])
}

model TicketValidation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  ticketId              String  @db.ObjectId
  purchaseId            String  @db.ObjectId
  validatorMembershipId String? @db.ObjectId

  ticketCode    String
  attendeeName  String?
  attendeeEmail String?

  validatedAt   DateTime @default(now())
  entryPoint    String?
  gateNumber    String?
  isValid       Boolean  @default(true)
  invalidReason String?
  isReentry     Boolean  @default(false)

  ticket    Ticket         @relation(fields: [ticketId], references: [id])
  purchase  TicketPurchase @relation(fields: [purchaseId], references: [id])
  validator Membership?    @relation("ValidatorMembership", fields: [validatorMembershipId], references: [id])

  @@index([ticketId])
  @@index([purchaseId])
  @@index([validatorMembershipId])
  @@index([ticketCode])
}

// ========================
// INVOICES & BILLING
// ========================
model Invoice {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  invoiceNumber  String @unique
  organizationId String @db.ObjectId
  membershipId   String @db.ObjectId

  amount      Float
  currency    String    @default("USD")
  description String?
  dueDate     DateTime?
  items       Json      @default("[]")

  status      InvoiceStatus @default(DRAFT)
  paidAt      DateTime?
  paidBy      String?       @db.ObjectId
  cancelledAt DateTime?

  createdBy String @db.ObjectId

  organization Organization @relation(fields: [organizationId], references: [id])
  membership   Membership   @relation(fields: [membershipId], references: [id])
  creator      User         @relation("InvoiceCreator", fields: [createdBy], references: [id])
  payer        User?        @relation("InvoicePayer", fields: [paidBy], references: [id])

  membershipItemId String?         @db.ObjectId
  membershipItem   MembershipItem? @relation(fields: [membershipItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([membershipId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model Payment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId   String  @db.ObjectId
  houseId          String? @db.ObjectId
  userId           String  @db.ObjectId
  ticketPurchaseId String? @db.ObjectId

  stripePaymentId  String
  amount           Float
  currency         String  @default("USD")
  description      String?
  metadata         Json    @default("{}")

  status     PaymentStatus @default(PENDING)
  paidAt     DateTime?
  refundedAt DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id])
  house          House?          @relation(fields: [houseId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  ticketPurchase TicketPurchase? @relation(fields: [ticketPurchaseId], references: [id])

  membershipItemId String?         @db.ObjectId
  membershipItem   MembershipItem? @relation(fields: [membershipItemId], references: [id])
  
  customerId   String?   @db.ObjectId
  customer     Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([userId])
  @@index([ticketPurchaseId])
  @@index([stripePaymentId])
  @@index([customerId])
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
}

// ========================
// COMMUNICATIONS
// ========================
model Communication {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId
  createdBy      String  @db.ObjectId

  subject String
  body    String
  type    CommunicationType @default(EMAIL)

  recipientType  RecipientType @default(ALL_MEMBERS)
  segmentFilters Json?

  status       CommunicationStatus @default(DRAFT)
  scheduledFor DateTime?
  sentAt       DateTime?

  sentCount    Int @default(0)
  openedCount  Int @default(0)
  clickedCount Int @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])
  creator      User         @relation("CommunicationCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([houseId, status])
}

enum CommunicationType {
  EMAIL
  ANNOUNCEMENT
  PUSH_NOTIFICATION
}

enum RecipientType {
  ALL_MEMBERS
  HOUSE_MEMBERS
  EVENT_ATTENDEES
  TICKET_BUYERS
  CUSTOM_SEGMENT
}

enum CommunicationStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

// ========================
// REPORTS & ANALYTICS
// ========================
model Report {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId

  type        ReportType
  title       String
  description String?

  parameters Json
  data       Json

  generatedBy String            @db.ObjectId
  generatedAt DateTime          @default(now())
  accessLevel ReportAccessLevel @default(ORGANIZATION)

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])
  generator    User         @relation("ReportGenerator", fields: [generatedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, type])
  @@index([houseId, type])
}

enum ReportType {
  MEMBERSHIP_GROWTH
  EVENT_ATTENDANCE
  REVENUE_ANALYSIS
  ENGAGEMENT_METRICS
  EMAIL_PERFORMANCE
  TICKET_SALES
  PLATFORM_OVERVIEW
}

enum ReportAccessLevel {
  HOUSE_ONLY
  ORGANIZATION
  PLATFORM
}

// ========================
// AUDIT LOGS
// ========================
model AuditLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId    String? @db.ObjectId
  userEmail String?
  userIp    String?
  userAgent String?

  action     String
  entityType String
  entityId   String?

  organizationId String? @db.ObjectId
  houseId        String? @db.ObjectId

  oldValues Json?
  newValues Json?
  metadata  Json?

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  house        House?        @relation(fields: [houseId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([organizationId, action])
  @@index([houseId, action])
  @@index([entityType, entityId])
}

// ========================
// MEMBERSHIP PLANS & SUBSCRIPTIONS
// ========================
model MembershipPlan {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String  @db.ObjectId
  houseId        String? @db.ObjectId

  name        String
  description String?
  type        MembershipPlanType   @default(STANDARD)
  status      MembershipPlanStatus @default(ACTIVE)

  features Json @default("[]")

  isPublic         Boolean @default(true)
  requiresApproval Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House?       @relation(fields: [houseId], references: [id])

  applications MembershipApplication[]
  memberships  MembershipItem[]
  prices       PlanPrice[]
  
  stripeProductId String?
  stripePriceIds  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([houseId])
}

model PlanPrice {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  membershipPlanId String         @db.ObjectId
  billingFrequency BillingFrequency
  amount           Float
  currency         String         @default("USD")
  setupFee         Float?         @default(0)
  vatRate          Float?         @default(0)
  stripePriceId    String?
  
  membershipPlan   MembershipPlan @relation(fields: [membershipPlanId], references: [id])
  membershipItems  MembershipItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([membershipPlanId, billingFrequency])
  @@index([membershipPlanId])
}

enum MembershipPlanType {
  STANDARD
  PREMIUM
  VIP
  CUSTOM
}

enum MembershipPlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum BillingFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

// ========================
// MEMBERSHIP APPLICATIONS
// ========================
model MembershipApplication {
  id               String @id @default(auto()) @map("_id") @db.ObjectId
  organizationId   String @db.ObjectId
  membershipPlanId String @db.ObjectId

  firstName String
  lastName  String
  email     String
  phone     String?
  company   String?
  position  String?

  status          ApplicationStatus @default(PENDING)
  notes           String?
  reviewedBy      String?           @db.ObjectId
  reviewedAt      DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  documents Json @default("[]")
  metadata  Json @default("{}")

  organization   Organization   @relation(fields: [organizationId], references: [id])
  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id])
  reviewer       User?          @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])

  membership MembershipItem?

  reviewToken          String?
  reviewTokenSentAt    DateTime?
  selectedPlanId       String?   @db.ObjectId
  selectedFrequency    BillingFrequency?
  selectedPriceId      String?   @db.ObjectId
  selectedAmount       Float?
  membershipNumber     String?
  initiationFee        Float?
  isInitiationWaived   Boolean   @default(false)
  proratedAmount       Float?
  finalAmount          Float?
  stripePaymentMethodId String?
  stripePaymentIntentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([membershipPlanId])
  @@index([email])
  @@index([reviewToken])
  @@index([membershipNumber])
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  WAITLIST
  CANCELLED
}

// ========================
// MEMBERSHIP ITEMS (ACTIVE SUBSCRIPTIONS)
// ========================
model MembershipItem {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  organizationId   String  @db.ObjectId
  membershipPlanId String  @db.ObjectId
  planPriceId      String? @db.ObjectId
  userId           String  @db.ObjectId
  applicationId    String? @unique @db.ObjectId

  status    MembershipItemStatus @default(ACTIVE)
  startDate DateTime             @default(now())
  endDate   DateTime?
  cancelAt  DateTime?

  billingFrequency BillingFrequency
  amount           Float
  currency         String           @default("USD")
  vatRate          Float?           @default(0)
  setupFee         Float?           @default(0)

  customerId            String?   @db.ObjectId
  customer              Customer? @relation(fields: [customerId], references: [id])
  stripeSubscriptionId  String?
  paymentStatus         PaymentStatus @default(PENDING)
  nextBillingDate       DateTime?
  lastBilledAt          DateTime?
  failedPaymentCount    Int       @default(0)
  stripePaymentIntentId String?

  cancellationReason String?
  cancelledBy        String?   @db.ObjectId
  cancelledAt        DateTime?
  pausedAt           DateTime?
  resumedAt          DateTime?

  organization    Organization           @relation(fields: [organizationId], references: [id])
  membershipPlan  MembershipPlan         @relation(fields: [membershipPlanId], references: [id])
  planPrice       PlanPrice?             @relation(fields: [planPriceId], references: [id])
  user            User                   @relation(fields: [userId], references: [id])
  application     MembershipApplication? @relation(fields: [applicationId], references: [id])
  cancelledByUser User?                  @relation("MembershipCanceller", fields: [cancelledBy], references: [id])

  invoices Invoice[]
  payments Payment[]
  
  cancellationRequests CancellationRequest[]

  initiationFeePaid   Float?
  proratedAdjustment  Float?
  membershipNumber    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([userId])
  @@index([membershipPlanId])
  @@index([customerId])
  @@index([membershipNumber])
}

enum MembershipItemStatus {
  ACTIVE
  PENDING
  PAUSED
  CANCELLED
  EXPIRED
}

// ========================
// CUSTOM FORMS
// ========================
model CustomForm {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String     @db.ObjectId
  houseId        String     @db.ObjectId
  title          String
  description    String?
  slug           String     @unique
  status         FormStatus @default(DRAFT)

  fields   Json @default("[]")
  settings Json @default("{}")

  submissions FormSubmission[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  house        House        @relation(fields: [houseId], references: [id])

  @@index([organizationId, houseId])
  @@index([status])
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model FormSubmission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  formId      String   @db.ObjectId
  data        Json
  submittedAt DateTime @default(now())

  userId    String? @db.ObjectId
  userEmail String?

  status     SubmissionStatus @default(PENDING)
  reviewedAt DateTime?
  reviewedBy String?          @db.ObjectId
  notes      String?

  form     CustomForm @relation(fields: [formId], references: [id])
  reviewer User?      @relation("FormSubmissionReviewer", fields: [reviewedBy], references: [id])

  @@index([formId])
  @@index([status])
  @@index([submittedAt])
}

enum SubmissionStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}