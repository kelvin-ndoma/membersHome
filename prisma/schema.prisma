  description String?
  thumbnail   String?

  streamUrl   String
  streamKey   String @unique
  viewerCount Int    @default(0)

  chatEnabled    Boolean @default(true)
  chatModeration Boolean @default(false)

  recordStream Boolean @default(false)
  recordingUrl String?

  scheduledFor DateTime?
  startedAt    DateTime?
  endedAt      DateTime?

  status LiveStreamStatus @default(SCHEDULED)

  messages CommunityPost[]
  viewers  LiveStreamViewer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Remove the duplicate @@index([streamKey]) since streamKey already has @unique

  @@index([communityId, status])
  @@index([hostId])
